{
  "name": "vscode-undotree",
  "displayName": "Undo Tree",
  "description": "Visualize and navigate undo history as a tree",
  "version": "0.1.9",
  "publisher": "mmiyaji",
  "repository": {
    "type": "git",
    "url": "https://github.com/mmiyaji/vscode-undotree.git"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "undotree.show",
        "title": "Undo Tree: Show"
      },
      {
        "command": "undotree.undo",
        "title": "Undo Tree: Undo"
      },
      {
        "command": "undotree.redo",
        "title": "Undo Tree: Redo"
      },
      {
        "command": "undotree.toggleTracking",
        "title": "Undo Tree: Toggle Tracking for Current Extension"
      },
      {
        "command": "undotree.togglePause",
        "title": "Undo Tree: Pause / Resume"
      },
      {
        "command": "undotree.compact",
        "title": "Undo Tree: Compact History"
      }
    ],
    "configuration": {
      "title": "Undo Tree",
      "properties": {
        "undotree.enabledExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".txt",
            ".md"
          ],
          "markdownDescription": "File extensions to automatically track undo history. Example: `[\".txt\", \".md\", \".js\"]`"
        },
        "undotree.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Filename patterns to exclude from tracking. Supports `*` wildcard. Example: `[\"*.min.*\", \"CHANGELOG*\", \".env*\"]`"
        }
      }
    },
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "undotree.treeView",
          "name": "Undo Tree"
        }
      ]
    },
    "keybindings": [
      {
        "command": "undotree.show",
        "key": "ctrl+shift+u",
        "mac": "cmd+shift+u"
      }
    ]
  },
  "scripts": {
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "package": "webpack --mode production",
    "vscode:prepublish": "npm run package",
    "test": "jest",
    "report": "jest --json --outputFile=test-report.json && node scripts/generate-report.js",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^vscode$": "<rootDir>/src/__mocks__/vscode.ts"
    },
    "testMatch": [
      "**/src/__tests__/**/*.test.ts"
    ]
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.0",
    "typescript": "^5.4.0",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.0"
  }
}
